@model Tashyeed.Web.ViewModels.AdminDashboard.AdminDashboardVM
@{
    ViewData["Title"] = "لوحة التحكم";
    Layout = "_DashboardLayout";
}

<div class="page-header">
    <h2 class="page-title">لوحة التحكم</h2>
</div>

<!-- Stats Cards -->
<div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 32px;">
    <div class="dash-card" style="padding: 24px;">
        <p class="form-label-dash">إجمالي المشاريع</p>
        <p style="font-family: 'Playfair Display', serif; font-size: 2.2rem; font-weight: 700; color: var(--gold);">@Model.TotalProjects</p>
    </div>
    <div class="dash-card" style="padding: 24px;">
        <p class="form-label-dash">مشاريع نشطة</p>
        <p style="font-family: 'Playfair Display', serif; font-size: 2.2rem; font-weight: 700; color: #4ade80;">@Model.ActiveProjects</p>
    </div>
    <div class="dash-card" style="padding: 24px;">
        <p class="form-label-dash">مشاريع معلقة</p>
        <p style="font-family: 'Playfair Display', serif; font-size: 2.2rem; font-weight: 700; color: var(--gold-light);">@Model.OnHoldProjects</p>
    </div>
    <div class="dash-card" style="padding: 24px;">
        <p class="form-label-dash">مشاريع منتهية</p>
        <p style="font-family: 'Playfair Display', serif; font-size: 2.2rem; font-weight: 700; color: var(--text-muted);">@Model.CompletedProjects</p>
    </div>
</div>

<div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; margin-bottom: 32px;">
    <div class="dash-card" style="padding: 24px;">
        <p class="form-label-dash">إجمالي الموظفين</p>
        <p style="font-family: 'Playfair Display', serif; font-size: 2.2rem; font-weight: 700; color: var(--gold);">@Model.TotalUsers</p>
    </div>
    <div class="dash-card" style="padding: 24px;">
        <p class="form-label-dash">موظفين نشطين</p>
        <p style="font-family: 'Playfair Display', serif; font-size: 2.2rem; font-weight: 700; color: #4ade80;">@Model.ActiveUsers</p>
    </div>
</div>

<!-- الرسم البياني -->
<div class="dash-card" style="padding: 24px; margin-bottom: 32px;">
    <h3 style="font-family: 'Playfair Display', serif; color: var(--white); margin-bottom: 20px;">
        المصاريف الشهرية - @DateTime.Now.Year
    </h3>
    <canvas id="expensesChart" height="100"></canvas>
</div>

<!-- Quick Access -->
<div>
    <h3 style="font-family: 'Playfair Display', serif; color: var(--white); margin-bottom: 20px;">وصول سريع</h3>
    <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px;">

        <a asp-controller="Projects" asp-action="Index" style="text-decoration: none;">
            <div class="dash-card" style="padding: 24px; display: flex; align-items: center; gap: 16px; cursor: pointer;">
                <div style="width: 48px; height: 48px; background: rgba(201,168,76,0.1); border: 1px solid var(--border); border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.4rem;">
                    🏗️
                </div>
                <div>
                    <p style="color: var(--white); font-weight: 600; margin-bottom: 4px;">إدارة المشاريع</p>
                    <p style="color: var(--text-muted); font-size: 0.85rem;">عرض وإضافة وتعديل المشاريع</p>
                </div>
            </div>
        </a>

        <a asp-controller="UserManagement" asp-action="Index" style="text-decoration: none;">
            <div class="dash-card" style="padding: 24px; display: flex; align-items: center; gap: 16px; cursor: pointer;">
                <div style="width: 48px; height: 48px; background: rgba(201,168,76,0.1); border: 1px solid var(--border); border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.4rem;">
                    👥
                </div>
                <div>
                    <p style="color: var(--white); font-weight: 600; margin-bottom: 4px;">إدارة المستخدمين</p>
                    <p style="color: var(--text-muted); font-size: 0.85rem;">عرض وإضافة وتعطيل الموظفين</p>
                </div>
            </div>
        </a>

        <a asp-controller="ProjectAssignment" asp-action="Index" style="text-decoration: none;">
            <div class="dash-card" style="padding: 24px; display: flex; align-items: center; gap: 16px; cursor: pointer;">
                <div style="width: 48px; height: 48px; background: rgba(201,168,76,0.1); border: 1px solid var(--border); border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.4rem;">
                    📋
                </div>
                <div>
                    <p style="color: var(--white); font-weight: 600; margin-bottom: 4px;">تعيينات المشاريع</p>
                    <p style="color: var(--text-muted); font-size: 0.85rem;">تعيين الموظفين على المشاريع</p>
                </div>
            </div>
        </a>

        <a asp-controller="Accounting" asp-action="MonthlyReport" style="text-decoration: none;">
            <div class="dash-card" style="padding: 24px; display: flex; align-items: center; gap: 16px; cursor: pointer;">
                <div style="width: 48px; height: 48px; background: rgba(201,168,76,0.1); border: 1px solid var(--border); border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.4rem;">
                    📊
                </div>
                <div>
                    <p style="color: var(--white); font-weight: 600; margin-bottom: 4px;">التقرير الشهري</p>
                    <p style="color: var(--text-muted); font-size: 0.85rem;">عرض وتحميل التقارير المالية</p>
                </div>
            </div>
        </a>

    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
<script>
    const labels = ['يناير', 'فبراير', 'مارس', 'أبريل', 'مايو', 'يونيو',
                    'يوليو', 'أغسطس', 'سبتمبر', 'أكتوبر', 'نوفمبر', 'ديسمبر'];

    const custodies = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyCustodies));
    const expenses = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyExpenses));
    const procurement = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyProcurement));
    const workers = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyWorkers));

    const ctx = document.getElementById('expensesChart').getContext('2d');
    new Chart(ctx, {
        type: 'line',
        data: {
            labels: labels,
            datasets: [
                {
                    label: 'العهد',
                    data: custodies,
                    borderColor: '#c9a84c',
                    backgroundColor: 'rgba(201,168,76,0.1)',
                    tension: 0.4,
                    fill: true
                },
                {
                    label: 'المصاريف',
                    data: expenses,
                    borderColor: '#f87171',
                    backgroundColor: 'rgba(248,113,113,0.1)',
                    tension: 0.4,
                    fill: true
                },
                {
                    label: 'المشتريات',
                    data: procurement,
                    borderColor: '#60a5fa',
                    backgroundColor: 'rgba(96,165,250,0.1)',
                    tension: 0.4,
                    fill: true
                },
                {
                    label: 'العمالة',
                    data: workers,
                    borderColor: '#4ade80',
                    backgroundColor: 'rgba(74,222,128,0.1)',
                    tension: 0.4,
                    fill: true
                }
            ]
        },
        options: {
            responsive: true,
            plugins: {
                legend: {
                    labels: { color: '#a0a0a0' }
                }
            },
            scales: {
                x: {
                    ticks: { color: '#a0a0a0' },
                    grid: { color: 'rgba(255,255,255,0.05)' }
                },
                y: {
                    ticks: { color: '#a0a0a0' },
                    grid: { color: 'rgba(255,255,255,0.05)' }
                }
            }
        }
    });
</script>