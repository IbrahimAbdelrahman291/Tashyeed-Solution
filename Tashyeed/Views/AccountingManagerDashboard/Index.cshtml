@model Tashyeed.Web.ViewModels.AccountingDashboard.AccountingManagerDashboardVM

@{
    ViewData["Title"] = "لوحة تحكم المحاسب";
    Layout = "_DashboardLayout";
}

<div class="page-header">
    <h2 class="page-title">لوحة تحكم المحاسب</h2>
</div>

<!-- Stats Cards -->
<div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 32px;">
    <div class="dash-card" style="padding: 24px;">
        <p class="form-label-dash">إجمالي المشاريع</p>
        <p style="font-family: 'Playfair Display', serif; font-size: 2.2rem; font-weight: 700; color: var(--gold);">@Model.TotalProjects</p>
    </div>
    <div class="dash-card" style="padding: 24px;">
        <p class="form-label-dash">إجمالي المصروف</p>
        <p style="font-family: 'Playfair Display', serif; font-size: 2.2rem; font-weight: 700; color: #f87171;">@Model.TotalSpent.ToString("N2") SAR</p>
    </div>
    <div class="dash-card" style="padding: 24px;">
        <p class="form-label-dash">إجمالي العهد</p>
        <p style="font-family: 'Playfair Display', serif; font-size: 2.2rem; font-weight: 700; color: var(--gold-light);">@Model.TotalCustodies.ToString("N2") SAR</p>
    </div>
    <div class="dash-card" style="padding: 24px;">
        <p class="form-label-dash">إجمالي المشتريات</p>
        <p style="font-family: 'Playfair Display', serif; font-size: 2.2rem; font-weight: 700; color: var(--gold);">@Model.TotalProcurement.ToString("N2") SAR</p>
    </div>
    <div class="dash-card" style="padding: 24px;">
        <p class="form-label-dash">إجمالي المصاريف</p>
        <p style="font-family: 'Playfair Display', serif; font-size: 2.2rem; font-weight: 700; color: var(--gold);">@Model.TotalExpenses.ToString("N2") SAR</p>
    </div>
    <div class="dash-card" style="padding: 24px;">
        <p class="form-label-dash">إجمالي رواتب العمالة</p>
        <p style="font-family: 'Playfair Display', serif; font-size: 2.2rem; font-weight: 700; color: var(--gold);">@Model.TotalWorkerPayments.ToString("N2") SAR</p>
    </div>
</div>

<!-- Quick Access -->
<div>
    <h3 style="font-family: 'Playfair Display', serif; color: var(--white); margin-bottom: 20px;">وصول سريع</h3>
    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;">

        <a asp-controller="Accounting" asp-action="Projects" style="text-decoration: none;">
            <div class="dash-card" style="padding: 24px; display: flex; align-items: center; gap: 16px; cursor: pointer;">
                <div style="width: 48px; height: 48px; background: rgba(201,168,76,0.1); border: 1px solid var(--border); border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.4rem;">
                    🏗️
                </div>
                <div>
                    <p style="color: var(--white); font-weight: 600; margin-bottom: 4px;">المشاريع</p>
                    <p style="color: var(--text-muted); font-size: 0.85rem;">عرض كل المشاريع ومصاريفها</p>
                </div>
            </div>
        </a>

        <a asp-controller="Accounting" asp-action="Custodies" style="text-decoration: none;">
            <div class="dash-card" style="padding: 24px; display: flex; align-items: center; gap: 16px; cursor: pointer;">
                <div style="width: 48px; height: 48px; background: rgba(201,168,76,0.1); border: 1px solid var(--border); border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.4rem;">
                    💰
                </div>
                <div>
                    <p style="color: var(--white); font-weight: 600; margin-bottom: 4px;">العهد</p>
                    <p style="color: var(--text-muted); font-size: 0.85rem;">عرض كل العهد</p>
                </div>
            </div>
        </a>

        <a asp-controller="Accounting" asp-action="Expenses" style="text-decoration: none;">
            <div class="dash-card" style="padding: 24px; display: flex; align-items: center; gap: 16px; cursor: pointer;">
                <div style="width: 48px; height: 48px; background: rgba(201,168,76,0.1); border: 1px solid var(--border); border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.4rem;">
                    🧾
                </div>
                <div>
                    <p style="color: var(--white); font-weight: 600; margin-bottom: 4px;">المصاريف</p>
                    <p style="color: var(--text-muted); font-size: 0.85rem;">عرض كل المصاريف والفواتير</p>
                </div>
            </div>
        </a>

        <a asp-controller="Accounting" asp-action="Procurement" style="text-decoration: none;">
            <div class="dash-card" style="padding: 24px; display: flex; align-items: center; gap: 16px; cursor: pointer;">
                <div style="width: 48px; height: 48px; background: rgba(201,168,76,0.1); border: 1px solid var(--border); border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.4rem;">
                    🛒
                </div>
                <div>
                    <p style="color: var(--white); font-weight: 600; margin-bottom: 4px;">المشتريات</p>
                    <p style="color: var(--text-muted); font-size: 0.85rem;">عرض كل المشتريات والفواتير</p>
                </div>
            </div>
        </a>

        <a asp-controller="Accounting" asp-action="Workers" style="text-decoration: none;">
            <div class="dash-card" style="padding: 24px; display: flex; align-items: center; gap: 16px; cursor: pointer;">
                <div style="width: 48px; height: 48px; background: rgba(201,168,76,0.1); border: 1px solid var(--border); border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.4rem;">
                    👷
                </div>
                <div>
                    <p style="color: var(--white); font-weight: 600; margin-bottom: 4px;">العمالة</p>
                    <p style="color: var(--text-muted); font-size: 0.85rem;">عرض مصاريف العمالة</p>
                </div>
            </div>
        </a>

        <a asp-controller="Accounting" asp-action="MonthlyReport" style="text-decoration: none;">
            <div class="dash-card" style="padding: 24px; display: flex; align-items: center; gap: 16px; cursor: pointer;">
                <div style="width: 48px; height: 48px; background: rgba(201,168,76,0.1); border: 1px solid var(--border); border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.4rem;">
                    📊
                </div>
                <div>
                    <p style="color: var(--white); font-weight: 600; margin-bottom: 4px;">التقرير الشهري</p>
                    <p style="color: var(--text-muted); font-size: 0.85rem;">إنشاء وعرض التقارير الشهرية</p>
                </div>
            </div>
        </a>

    </div>
</div>