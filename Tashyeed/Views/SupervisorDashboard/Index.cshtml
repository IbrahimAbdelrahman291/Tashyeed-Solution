@model Tashyeed.Web.ViewModels.SupervisorMDashboard.SupervisorDashboardVM
@{
    ViewData["Title"] = "لوحة تحكم المشرف";
    Layout = "_DashboardLayout";
}
@if (TempData["Error"] != null)
{
    <div style="background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3);
                    color: #f87171; padding: 12px 20px; border-radius: 8px; margin-bottom: 16px;">
        @TempData["Error"]
    </div>
}

<div class="page-header">
    <h2 class="page-title">لوحة تحكم المشرف</h2>
</div>

<div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 32px;">
    <div class="dash-card" style="padding: 24px;">
        <p class="form-label-dash">عهد معلقة</p>
        <p style="font-family: 'Playfair Display', serif; font-size: 2.2rem; font-weight: 700; color: var(--gold-light);">@Model.PendingCustodies</p>
    </div>
    <div class="dash-card" style="padding: 24px;">
        <p class="form-label-dash">عهد مؤكدة</p>
        <p style="font-family: 'Playfair Display', serif; font-size: 2.2rem; font-weight: 700; color: #4ade80;">@Model.ConfirmedCustodies</p>
    </div>
    <div class="dash-card" style="padding: 24px;">
        <p class="form-label-dash">الرصيد المتاح</p>
        <p style="font-family: 'Playfair Display', serif; font-size: 2.2rem; font-weight: 700; color: var(--gold);">@Model.TotalBalance.ToString("N2") SAR</p>
    </div>
</div>

<!-- Quick Access -->
<div>
    <h3 style="font-family: 'Playfair Display', serif; color: var(--white); margin-bottom: 20px;">وصول سريع</h3>
    <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px;">

        <a asp-controller="Custody" asp-action="MyCustodies" style="text-decoration: none;">
            <div class="dash-card" style="padding: 24px; display: flex; align-items: center; gap: 16px; cursor: pointer;">
                <div style="width: 48px; height: 48px; background: rgba(201,168,76,0.1); border: 1px solid var(--border); border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.4rem;">
                    💰
                </div>
                <div>
                    <p style="color: var(--white); font-weight: 600; margin-bottom: 4px;">عهدي</p>
                    <p style="color: var(--text-muted); font-size: 0.85rem;">عرض وتأكيد العهد المعلقة</p>
                </div>
            </div>
        </a>
        <a asp-controller="Expenses" asp-action="MyExpenses" style="text-decoration: none;">
            <div class="dash-card" style="padding: 24px; display: flex; align-items: center; gap: 16px; cursor: pointer;">
                <div style="width: 48px; height: 48px; background: rgba(201,168,76,0.1); border: 1px solid var(--border); border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.4rem;">
                    🧾
                </div>
                <div>
                    <p style="color: var(--white); font-weight: 600; margin-bottom: 4px;">مصاريفي</p>
                    <p style="color: var(--text-muted); font-size: 0.85rem;">عرض وإضافة مصاريف</p>
                </div>
            </div>
        </a>
        <a asp-controller="Workers" asp-action="MyWorkers" style="text-decoration: none;">
            <div class="dash-card" style="padding: 24px; display: flex; align-items: center; gap: 16px; cursor: pointer;">
                <div style="width: 48px; height: 48px; background: rgba(201,168,76,0.1); border: 1px solid var(--border); border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.4rem;">
                    👷
                </div>
                <div>
                    <p style="color: var(--white); font-weight: 600; margin-bottom: 4px;">العمال</p>
                    <p style="color: var(--text-muted); font-size: 0.85rem;">إدارة العمال والحضور</p>
                </div>
            </div>
        </a>
        <a asp-controller="Workers" asp-action="MyRequests" style="text-decoration: none;">
            <div class="dash-card" style="padding: 24px; display: flex; align-items: center; gap: 16px; cursor: pointer;">
                <div style="width: 48px; height: 48px; background: rgba(201,168,76,0.1); border: 1px solid var(--border); border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.4rem;">
                    📋
                </div>
                <div>
                    <p style="color: var(--white); font-weight: 600; margin-bottom: 4px;">طلبات العمالة</p>
                    <p style="color: var(--text-muted); font-size: 0.85rem;">عرض وإضافة طلبات العمالة</p>
                </div>
            </div>
        </a>
    </div>
</div>