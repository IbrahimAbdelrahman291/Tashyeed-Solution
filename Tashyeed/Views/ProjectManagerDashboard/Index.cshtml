@model Tashyeed.Web.ViewModels.PMDashboard.ProjectManagerDashboardVM
@{
    ViewData["Title"] = "لوحة تحكم مدير المشروع";
    Layout = "_DashboardLayout";
}

<div class="page-header">
    <h2 class="page-title">لوحة تحكم مدير المشروع</h2>
</div>

<!-- Stats Cards -->
<div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 32px;">
    <div class="dash-card" style="padding: 24px;">
        <p class="form-label-dash">إجمالي مشاريعي</p>
        <p style="font-family: 'Playfair Display', serif; font-size: 2.2rem; font-weight: 700; color: var(--gold);">@Model.TotalProjects</p>
    </div>
    <div class="dash-card" style="padding: 24px;">
        <p class="form-label-dash">مشاريع نشطة</p>
        <p style="font-family: 'Playfair Display', serif; font-size: 2.2rem; font-weight: 700; color: #4ade80;">@Model.ActiveProjects</p>
    </div>
    <div class="dash-card" style="padding: 24px;">
        <p class="form-label-dash">عهد معلقة</p>
        <p style="font-family: 'Playfair Display', serif; font-size: 2.2rem; font-weight: 700; color: var(--gold-light);">@Model.PendingCustodies</p>
    </div>
    <div class="dash-card" style="padding: 24px;">
        <p class="form-label-dash">إجمالي العهد</p>
        <p style="font-family: 'Playfair Display', serif; font-size: 2.2rem; font-weight: 700; color: var(--text-muted);">@Model.TotalCustodiesSent</p>
    </div>
</div>

<!-- Quick Access -->
<div>
    <h3 style="font-family: 'Playfair Display', serif; color: var(--white); margin-bottom: 20px;">وصول سريع</h3>
    <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px;">

        <a asp-controller="Custody" asp-action="Index" style="text-decoration: none;">
            <div class="dash-card" style="padding: 24px; display: flex; align-items: center; gap: 16px; cursor: pointer;">
                <div style="width: 48px; height: 48px; background: rgba(201,168,76,0.1); border: 1px solid var(--border); border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.4rem;">
                    💰
                </div>
                <div>
                    <p style="color: var(--white); font-weight: 600; margin-bottom: 4px;">العهد</p>
                    <p style="color: var(--text-muted); font-size: 0.85rem;">عرض وإضافة عهد</p>
                </div>
            </div>
        </a>

        <a asp-controller="Custody" asp-action="Assign"
           asp-route-returnUrl="@Url.Action("Index", "ProjectManagerDashboard")"
           style="text-decoration: none;">
            <div class="dash-card" style="padding: 24px; display: flex; align-items: center; gap: 16px; cursor: pointer;">
                <div style="width: 48px; height: 48px; background: rgba(201,168,76,0.1); border: 1px solid var(--border); border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.4rem;">
                    ➕
                </div>
                <div>
                    <p style="color: var(--white); font-weight: 600; margin-bottom: 4px;">إضافة عهدة</p>
                    <p style="color: var(--text-muted); font-size: 0.85rem;">تعيين عهدة لمشرف أو مدير مشتريات</p>
                </div>
            </div>
        </a>
        <a asp-controller="Workers" asp-action="Requests" style="text-decoration: none;">
            <div class="dash-card" style="padding: 24px; display: flex; align-items: center; gap: 16px; cursor: pointer;">
                <div style="width: 48px; height: 48px; background: rgba(201,168,76,0.1); border: 1px solid var(--border); border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 1.4rem;">
                    👷
                </div>
                <div>
                    <p style="color: var(--white); font-weight: 600; margin-bottom: 4px;">طلبات العمالة</p>
                    <p style="color: var(--text-muted); font-size: 0.85rem;">الموافقة على طلبات العمالة</p>
                </div>
            </div>
        </a>

    </div>
</div>