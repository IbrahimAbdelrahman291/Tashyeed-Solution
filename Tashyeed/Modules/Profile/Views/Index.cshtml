@model Tashyeed.Web.Modules.Profile.ViewModels.ProfileVM
@{
    ViewData["Title"] = "الملف الشخصي";
}

<div class="page-header">
    <h2 class="page-title">الملف الشخصي</h2>
</div>

@if (TempData["Success"] != null)
{
    <div style="background: rgba(74,222,128,0.1); border: 1px solid rgba(74,222,128,0.3);
                    color: #4ade80; padding: 12px 20px; border-radius: 8px; margin-bottom: 16px;">
        @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div style="background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3);
                    color: #f87171; padding: 12px 20px; border-radius: 8px; margin-bottom: 16px;">
        @TempData["Error"]
    </div>
}

<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px;">

    <!-- بيانات الملف الشخصي -->
    <div class="dash-card" style="padding: 32px;">
        <div style="display: flex; align-items: center; gap: 20px; margin-bottom: 32px;">
            <div style="width: 64px; height: 64px; background: rgba(201,168,76,0.15);
                        border: 1px solid var(--border); border-radius: 50%;
                        display: flex; align-items: center; justify-content: center; font-size: 1.8rem;">
                👤
            </div>
            <div>
                <p style="color: var(--white); font-weight: 700; font-size: 1.2rem;">@Model.FullName</p>
                <p style="color: var(--text-muted); font-size: 0.85rem;">@Model.Email</p>
            </div>
        </div>

        <div style="display: flex; flex-direction: column; gap: 16px;">
            <div style="border-bottom: 1px solid var(--border); padding-bottom: 16px;">
                <p class="form-label-dash">الدور الوظيفي</p>
                <p style="color: var(--white); font-weight: 600;">@Model.Role</p>
            </div>
            <div style="border-bottom: 1px solid var(--border); padding-bottom: 16px;">
                <p class="form-label-dash">البريد الإلكتروني</p>
                <p style="color: var(--white); font-weight: 600;">@Model.Email</p>
            </div>
            <div>
                <p class="form-label-dash">المشروع</p>
                <p style="color: var(--white); font-weight: 600;">@(Model.ProjectName ?? "غير معين")</p>
            </div>
        </div>
    </div>

    <!-- تغيير الباسورد -->
    <div class="dash-card" style="padding: 32px;">
        <h3 style="color: var(--white); font-size: 1.1rem; margin-bottom: 24px;">تغيير الباسورد</h3>

        <form asp-action="ChangePassword" method="post">
            @Html.AntiForgeryToken()

            <div class="form-group-dash">
                <label class="form-label-dash">الباسورد الحالي</label>
                <input type="password" name="CurrentPassword"
                       class="form-control-dash" placeholder="••••••••" />
            </div>

            <div class="form-group-dash">
                <label class="form-label-dash">الباسورد الجديد</label>
                <input type="password" name="NewPassword"
                       class="form-control-dash" placeholder="••••••••" />
            </div>

            <div class="form-group-dash">
                <label class="form-label-dash">تأكيد الباسورد الجديد</label>
                <input type="password" name="ConfirmPassword"
                       class="form-control-dash" placeholder="••••••••" />
            </div>

            <button type="submit" class="btn-gold" style="width: 100%; margin-top: 8px;">
                تغيير الباسورد
            </button>
        </form>
    </div>

</div>