@model IEnumerable<CustodyListVM>

@{
    ViewData["Title"] = "عهدي";
}

<div class="page-header">
    <h2 class="page-title">عهدي</h2>
    <a asp-controller="@(User.IsInRole(RoleNames.Supervisor) ? "SupervisorDashboard" : "ProcurementManagerDashboard")"
       asp-action="Index" class="btn-action btn-edit">رجوع</a>
</div>

<div class="dash-card">
    <table class="dash-table">
        <thead>
            <tr>
                <th>المشروع</th>
                <th>من</th>
                <th>المبلغ</th>
                <th>المتبقي</th>
                <th>الحالة</th>
                <th>التاريخ</th>
                <th>الإجراءات</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var custody in Model)
            {
                <tr>
                    <td>@custody.ProjectName</td>
                    <td>@custody.GivenByName</td>
                    <td>@custody.Amount.ToString("N2") SAR</td>
                    <td>@custody.RemainingAmount.ToString("N2") SAR</td>
                    <td>
                        @switch (custody.Status)
                        {
                            case CustodyStatus.Pending:
                                <span class="badge-onhold">معلقة</span>
                                break;
                            case CustodyStatus.Confirmed:
                                <span class="badge-active">مؤكدة</span>
                                break;
                            case CustodyStatus.Rejected:
                                <span class="badge-completed">مرفوضة</span>
                                break;
                        }
                    </td>
                    <td>@custody.CreatedAt.ToString("yyyy-MM-dd")</td>
                    <td>
                        @if (custody.Status == CustodyStatus.Pending)
                        {
                            <form asp-action="Confirm" method="post" style="display:inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="custodyId" value="@custody.Id" />
                                <button type="submit" class="btn-action btn-details">تأكيد</button>
                            </form>
                            <form asp-action="Reject" method="post" style="display:inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="custodyId" value="@custody.Id" />
                                <button type="submit" class="btn-action btn-delete"
                                        onclick="return confirm('متأكد إنك عايز ترفض العهدة دي؟')">
                                    رفض
                                </button>
                            </form>
                        }
                        else
                        {
                            <span style="color: var(--text-muted); font-size: 0.85rem;">-</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>