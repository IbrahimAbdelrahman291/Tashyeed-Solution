@model PurchaseOrderVM

@{
    ViewData["Title"] = "تنفيذ طلب الشراء";
}

<div class="page-header">
    <h2 class="page-title">تنفيذ طلب الشراء</h2>
    <a asp-action="Index" class="btn-action btn-edit">رجوع</a>
</div>

<div class="form-card" style="margin: 0 auto;">
    @if (!ViewData.ModelState.IsValid)
    {
        <div style="background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3);
                        color: #f87171; padding: 12px 16px; border-radius: 8px; margin-bottom: 24px;">
            @Html.ValidationSummary(false)
        </div>
    }
    <form asp-action="Order" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="PurchaseRequestId" />
        <input type="hidden" asp-for="ProjectId" />

        <label class="form-label-dash">طريقة الدفع</label>
        <select asp-for="PaymentMethod" class="form-control-dash">
            <option value="">-- اختر طريقة الدفع --</option>
            <option value="1">من العهدة</option>
            <option value="2">تحويل بنكي</option>
        </select>
        <span asp-validation-for="PaymentMethod" class="text-danger-dash"></span>

        <label class="form-label-dash">المبلغ الفعلي</label>
        <input asp-for="Amount" class="form-control-dash" type="number" step="0.01" placeholder="0.00" />
        <span asp-validation-for="Amount" class="text-danger-dash"></span>

        <label class="form-label-dash">صورة الفاتورة</label>
        <input asp-for="InvoiceImage" class="form-control-dash" type="file" accept="image/*" />
        <span asp-validation-for="InvoiceImage" class="text-danger-dash"></span>

        <div style="display:flex; gap:12px; margin-top:8px;">
            <button type="submit" class="btn-gold">تأكيد الشراء</button>
            <a asp-action="Index" class="btn-action btn-edit">رجوع</a>
        </div>
    </form>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}