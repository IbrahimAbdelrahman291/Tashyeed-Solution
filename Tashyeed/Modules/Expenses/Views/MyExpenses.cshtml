@model IEnumerable<ExpenseListVM>
@{
    ViewData["Title"] = "مصاريفي";
}
<div class="page-header">
    <h2 class="page-title">مصاريفي</h2>
    <div style="display:flex; gap:12px;">
        <a asp-controller="SupervisorDashboard" asp-action="Index" class="btn-action btn-edit">رجوع</a>
        <a asp-action="Add" class="btn-gold">+ مصروف جديد</a>
    </div>
</div>

<div class="dash-card">
    <div style="gap:12px; padding: 16px 0 20px 0;">
        <input type="date" id="dateFilter"
               class="form-control-dash" style="max-width: 200px; height: 42px; display:inline-block; margin-left: 12px;"
               onchange="filterTable()" />
        <button onclick="clearFilters()"
                style="background: transparent; border: 1px solid var(--border); color: var(--text-muted);
                       height: 42px; padding: 0 14px; border-radius: 8px; cursor: pointer; font-size: 0.85rem;
                       transition: all 0.2s;"
                onmouseover="this.style.borderColor='var(--gold)'; this.style.color='var(--gold)'"
                onmouseout="this.style.borderColor='var(--border)'; this.style.color='var(--text-muted)'">
            ✕ مسح الفلتر
        </button>
    </div>

    <table class="dash-table" id="expensesTable">
        <thead>
            <tr>
                <th>المشروع</th>
                <th>النوع</th>
                <th>المبلغ</th>
                <th>ملاحظات</th>
                <th>فاتورة</th>
                <th>الحالة</th>
                <th>التاريخ</th>
            </tr>
        </thead>
        <tbody id="tableBody">
            @foreach (var expense in Model)
            {
                <tr>
                    <td>@expense.ProjectName</td>
                    <td>
                        @if (expense.Type == ExpenseType.Food)
                        {
                            <span>🍔 أكل وشرب</span>
                        }
                        else
                        {
                            <span>🚗 موصلات</span>
                        }
                    </td>
                    <td>@expense.Amount.ToString("N2") SAR</td>
                    <td>@(expense.Notes ?? "-")</td>
                    <td>
                        @if (!string.IsNullOrEmpty(expense.InvoiceImagePath))
                        {
                            <a href="@expense.InvoiceImagePath" target="_blank" class="btn-action btn-details">عرض</a>
                        }
                        else
                        {
                            <span style="color: var(--text-muted);">-</span>
                        }
                    </td>
                    <td>
                        @switch (expense.Status)
                        {
                            case RequestStatus.Pending:
                                <span class="badge-onhold">معلقة</span>
                                break;
                            case RequestStatus.Approved:
                                <span class="badge-active">موافق عليها</span>
                                break;
                            case RequestStatus.Rejected:
                                <span class="badge-completed">مرفوضة</span>
                                break;
                        }
                    </td>
                    <td data-date="@expense.CreatedAt.ToString("yyyy-MM-dd")">@expense.CreatedAt.ToString("yyyy-MM-dd")</td>
                </tr>
            }
        </tbody>
    </table>
    <p id="noResults" style="display:none; color: var(--text-muted); padding: 20px; text-align:center;">
        مفيش نتائج
    </p>
</div>

<script>
    function filterTable() {
        const date = document.getElementById('dateFilter').value;
        const rows = document.querySelectorAll('#tableBody tr');
        let count = 0;

        rows.forEach(row => {
            const rowDate = row.cells[6].getAttribute('data-date');
            const matchDate = !date || rowDate === date;

            if (matchDate) {
                row.style.display = '';
                count++;
            } else {
                row.style.display = 'none';
            }
        });

        document.getElementById('noResults').style.display = count === 0 ? 'block' : 'none';
    }

    function clearFilters() {
        document.getElementById('dateFilter').value = '';
        filterTable();
    }
</script>