@model AddExpenseVM

@{
    ViewData["Title"] = "مصروف جديد";
}
@if (TempData["Error"] != null)
{
    <div style="background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3);
                        color: #f87171; padding: 12px 20px; border-radius: 8px; margin-bottom: 16px;">
        @TempData["Error"]
    </div>
}
<div class="page-header">
    <h2 class="page-title">إضافة مصروف جديد</h2>
    @if (User.IsInRole(RoleNames.Supervisor))
    {
        <a asp-action="MyExpenses" class="btn-action btn-edit">رجوع</a>
    }
    else
    {
        <a asp-action="Index" class="btn-action btn-edit">رجوع</a>
    }
</div>

<div class="form-card" style="margin: 0 auto;">
    <form asp-action="Add" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <label class="form-label-dash">المشروع</label>
        <select asp-for="ProjectId" class="form-control-dash" asp-items="ViewBag.Projects">
            <option value="">-- اختر المشروع --</option>
        </select>
        <span asp-validation-for="ProjectId" class="text-danger-dash"></span>

        <label class="form-label-dash">النوع</label>
        <select asp-for="Type" class="form-control-dash" asp-items="ViewBag.ExpenseTypes">
            <option value="">-- اختر النوع --</option>
        </select>
        <span asp-validation-for="Type" class="text-danger-dash"></span>

        <label class="form-label-dash">المبلغ</label>
        <input asp-for="Amount" class="form-control-dash" type="number" step="0.01" placeholder="0.00" />
        <span asp-validation-for="Amount" class="text-danger-dash"></span>

        <label class="form-label-dash">ملاحظات (اختياري)</label>
        <textarea asp-for="Notes" class="form-control-dash" rows="2" placeholder="أي ملاحظات إضافية"></textarea>

        <label class="form-label-dash">صورة الفاتورة</label>
        <input asp-for="InvoiceImage" class="form-control-dash" type="file" accept="image/*" />
        <span asp-validation-for="InvoiceImage" class="text-danger-dash"></span>

        <div style="display:flex; gap:12px; margin-top:8px;">
            <button type="submit" class="btn-gold">إضافة</button>
            @if (User.IsInRole(RoleNames.Supervisor))
            {
                <a asp-action="MyExpenses" class="btn-action btn-edit">رجوع</a>
            }
            else
            {
                <a asp-action="Index" class="btn-action btn-edit">رجوع</a>
            }
        </div>
    </form>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}