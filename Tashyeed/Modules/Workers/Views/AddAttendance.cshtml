@model DailyAttendanceVM

@{
    ViewData["Title"] = "حضور يومي";
}

<div class="page-header">
    <h2 class="page-title">تسجيل حضور - @Model.WorkerName</h2>
    <a asp-action="MyWorkers" class="btn-action btn-edit">رجوع</a>
</div>

<div class="form-card" style="margin: 0 auto;">
    <form asp-action="AddAttendance" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="WorkerId" />
        <input type="hidden" asp-for="WorkerName" />

        <label class="form-label-dash">التاريخ</label>
        <input asp-for="AttendanceDate" class="form-control-dash" type="date"
               max="@DateTime.Today.ToString("yyyy-MM-dd")" />
        <span asp-validation-for="AttendanceDate" class="text-danger-dash"></span>

        <div style="display:flex; align-items:center; gap:12px; margin-bottom:20px;">
            <input asp-for="IsPresent" type="checkbox" style="width:20px; height:20px; accent-color: var(--gold);" />
            <label class="form-label-dash" style="margin:0;">حضر اليوم</label>
        </div>

        <label class="form-label-dash">ساعات الأوفر تايم</label>
        <input asp-for="OvertimeHours" class="form-control-dash" type="number" step="0.5" min="0" placeholder="0" />
        <span asp-validation-for="OvertimeHours" class="text-danger-dash"></span>

        <div style="display:flex; gap:12px; margin-top:8px;">
            <button type="submit" class="btn-gold">حفظ</button>
            <a asp-action="MyWorkers" class="btn-action btn-edit">رجوع</a>
        </div>
    </form>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}