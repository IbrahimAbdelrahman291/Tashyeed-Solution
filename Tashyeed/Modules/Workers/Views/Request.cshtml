@model WorkerRequestVM

@{
    ViewData["Title"] = "طلب عمالة";
}

<div class="page-header">
    <h2 class="page-title">طلب عمالة جديد</h2>
    <a asp-action="MyWorkers" class="btn-action btn-edit">رجوع</a>
</div>

<div class="form-card" style="margin: 0 auto;">
    <form asp-action="Request" method="post">
        @Html.AntiForgeryToken()

        <label class="form-label-dash">المشروع</label>
        <select asp-for="ProjectId" class="form-control-dash" asp-items="ViewBag.Projects">
            <option value="">-- اختر المشروع --</option>
        </select>
        <span asp-validation-for="ProjectId" class="text-danger-dash"></span>

        <label class="form-label-dash">عدد العمال</label>
        <input asp-for="NumberOfWorkers" class="form-control-dash" type="number" min="1" placeholder="0" />
        <span asp-validation-for="NumberOfWorkers" class="text-danger-dash"></span>

        <label class="form-label-dash">نوع العمالة</label>
        <select asp-for="WorkerType" class="form-control-dash">
            <option value="">-- اختر النوع --</option>
            <option value="1">يومية</option>
            <option value="2">بالمشروع</option>
        </select>
        <span asp-validation-for="WorkerType" class="text-danger-dash"></span>

        <div style="display:flex; gap:12px; margin-top:8px;">
            <button type="submit" class="btn-gold">إرسال الطلب</button>
            <a asp-action="MyWorkers" class="btn-action btn-edit">رجوع</a>
        </div>
    </form>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}