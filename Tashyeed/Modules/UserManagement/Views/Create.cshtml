@model CreateUserVM

@{
    ViewData["Title"] = "مستخدم جديد";
}

<div class="page-header">
    <h2 class="page-title">مستخدم جديد</h2>
    <a asp-action="Index" class="btn-action btn-edit">رجوع</a>
</div>

<div class="form-card" style="margin: 0 auto;">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <label class="form-label-dash">الاسم الكامل</label>
        <input asp-for="FullName" class="form-control-dash" placeholder="مثال: أحمد محمد" />
        <span asp-validation-for="FullName" class="text-danger-dash"></span>

        <label class="form-label-dash">البريد الإلكتروني</label>
        <input asp-for="Email" class="form-control-dash" placeholder="example@tashyeed.com" />
        <span asp-validation-for="Email" class="text-danger-dash"></span>

        <label class="form-label-dash">كلمة المرور</label>
        <input asp-for="Password" class="form-control-dash" type="password" placeholder="••••••••" />
        <span asp-validation-for="Password" class="text-danger-dash"></span>

        <label class="form-label-dash">رقم الجوال (اختياري)</label>
        <input asp-for="Phone" class="form-control-dash" placeholder="05xxxxxxxx" />

        <label class="form-label-dash">رقم الهوية (اختياري)</label>
        <input asp-for="NationalId" class="form-control-dash" placeholder="1xxxxxxxxx" />

        <label class="form-label-dash">الدور</label>
        <select asp-for="Role" class="form-control-dash">
            <option value="">-- اختر الدور --</option>
            <option value="@RoleNames.ProjectManager">مدير مشروع</option>
            <option value="@RoleNames.ProcurementManager">مدير مشتريات</option>
            <option value="@RoleNames.Engineer">مهندس</option>
            <option value="@RoleNames.Supervisor">مشرف</option>
            <option value="@RoleNames.AccountingManager">محاسب</option>
        </select>
        <span asp-validation-for="Role" class="text-danger-dash"></span>

        <div style="display:flex; gap:12px; margin-top:8px;">
            <button type="submit" class="btn-gold">حفظ</button>
            <a asp-action="Index" class="btn-action btn-edit">رجوع</a>
        </div>
    </form>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}