@model Tashyeed.Web.Modules.UserManagement.ViewModels.AdminChangePasswordVM
@{
    ViewData["Title"] = "تغيير الباسورد";
}

<div class="page-header">
    <h2 class="page-title">تغيير باسورد - @Model.UserName</h2>
    <a asp-action="Index" class="btn-action btn-edit">رجوع</a>
</div>

@if (TempData["Error"] != null)
{
    <div style="background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.3);
                    color: #f87171; padding: 12px 20px; border-radius: 8px; margin-bottom: 16px;">
        @TempData["Error"]
    </div>
}

<div class="dash-card" style="padding: 32px; max-width: 500px;">
    <form asp-action="ChangePassword" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="UserId" value="@Model.UserId" />
        <input type="hidden" name="UserName" value="@Model.UserName" />

        <div class="form-group-dash">
            <label class="form-label-dash">الباسورد الجديد</label>
            <input type="password" name="NewPassword"
                   class="form-control-dash" placeholder="••••••••" />
            <span asp-validation-for="NewPassword" style="color:#f87171; font-size:0.85rem;"></span>
        </div>

        <div class="form-group-dash">
            <label class="form-label-dash">تأكيد الباسورد الجديد</label>
            <input type="password" name="ConfirmPassword"
                   class="form-control-dash" placeholder="••••••••" />
            <span asp-validation-for="ConfirmPassword" style="color:#f87171; font-size:0.85rem;"></span>
        </div>

        <button type="submit" class="btn-gold" style="width: 100%; margin-top: 8px;">
            تغيير الباسورد
        </button>
    </form>
</div>